# Celery worker image — for cloud deployment. For GPU nodes use an
# nvidia/cuda base image + the cu124 torch index instead of the CPU wheel.
# --pool=solo is REQUIRED with CUDA (contexts cannot survive prefork's fork()).
FROM python:3.12-slim

WORKDIR /srv

RUN pip install --no-cache-dir torch torchvision --index-url https://download.pytorch.org/whl/cpu \
    && pip install --no-cache-dir \
       fastapi pydantic-settings Pillow numpy google-genai openai-clip \
       celery redis pgvector "psycopg[binary]" alembic

COPY app ./app

CMD ["celery", "-A", "app.tasks.celery_app:celery", "worker", \
     "--pool=solo", "--concurrency=1", "--loglevel=info"]
